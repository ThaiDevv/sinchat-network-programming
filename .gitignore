# ============================================================
#  SinChat — .gitignore
#  Chỉ track source code (.java) và file test.
#  Mọi file build, IDE, OS, log, binary đều bị bỏ qua.
# ============================================================

# ---- Maven build output ----
target/
target/**
dependency-reduced-pom.xml

# ---- Compiled classes ----
*.class

# ---- IDE files ----
.idea/
*.iml
.claude/
.codebuddy/
.settings/
.project
.classpath
.vscode/

# ---- OS generated files ----
.DS_Store
Thumbs.db
Desktop.ini

# ---- Logs ----
*.log

# ---- Environment / secrets ----
.env
*.env
Code/Server/.env

# ---- Uploaded user content (avatars, attachments) ----
uploads/
uploads/avatars/
Code/Server/uploads/

# ---- Generated / temporary files ----
*.sql
sql.txt
API_DOCUMENTATION.md
test-reports/
out/
.deps/
